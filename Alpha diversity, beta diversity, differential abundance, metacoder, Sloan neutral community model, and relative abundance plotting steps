#-----------------------------Sloan Neutral Community Model (NCM), fit separately by Host_Phenotype (Sensitive / Water_saver / Water_spender)------------------------------------

library(phyloseq)
library(minpack.lm)
library(ggrepel) 
library(tidyverse)

#Select dataset
ps <- d16S_peanut_phyloseq_Bulk   # must have sample_data(ps)$Host_Phenotype and mus be RAW COUNTS

# ------------------------------------------------------------------
#fit Sloan neutral model to one OTU table (otu_mat must be samples (rows) x taxa (columns), RAW COUNTS!!)
fit_neutral_model <- function(otu_mat) {
  
#Community size used in the model (mean reads per sample)
N <- mean(rowSums(otu_mat))
  
#Mean relative abundance per taxon = proxy for metacommunity frequency (p)
rel_mat <- otu_mat / rowSums(otu_mat)
p.mean <- colMeans(rel_mat)
p.mean <- p.mean[p.mean > 0]
  
  #Observed occurrence frequency = proportion of samples where taxon is present
  otu_pa <- (otu_mat > 0) * 1
  freq.table <- colSums(otu_pa) / nrow(otu_pa)
  
  #Align taxa between the two vectors
  taxa_common <- intersect(names(p.mean), names(freq.table))
  d <- data.frame(
    taxon = taxa_common,
    p     = p.mean[taxa_common],
    freq  = freq.table[taxa_common]
  )
  d <- d[order(d$p), ]
  
  #Fit m (migration rate) via nonlinear least squares
  #freq_predicted = 1 - CDF of beta distribution parameterized by N*m*p
  m.fit <- nlsLM(
    freq ~ pbeta(1 / N, N * m * p, N * m * (1 - p), lower.tail = FALSE),
    data    = d,
    start   = list(m = 0.1),
    control = nls.lm.control(maxiter = 1000)
  )
  
  m.est <- coef(m.fit)[["m"]]
  m.ci  <- tryCatch(confint(m.fit, level = 0.95), error = function(e) c(NA, NA))
  
  #Predicted frequency and 95% binomial prediction interval per taxon
  d$freq.pred    <- pbeta(1 / N, N * m.est * d$p, N * m.est * (1 - d$p), lower.tail = FALSE)
  n_samples      <- nrow(otu_mat)
  d$pred.ci_low  <- qbinom(0.025, n_samples, d$freq.pred) / n_samples
  d$pred.ci_high <- qbinom(0.975, n_samples, d$freq.pred) / n_samples
  
  #Classify each taxon relative to the neutral prediction
  d$fit_class <- with(d, ifelse(
    freq > pred.ci_high, "Above prediction",
    ifelse(freq < pred.ci_low, "Below prediction", "Neutral (within prediction)")
  ))
  
  #Neutral model R2 (Sloan-style pseudo-R2: 1 - SSE/SST)
  Rsqr <- 1 - sum((d$freq - d$freq.pred)^2) / sum((d$freq - mean(d$freq))^2)
  
  list(
    data = d,
    m    = m.est,
    m.ci = m.ci,
    Nm   = N * m.est,
    R2   = Rsqr,
    N    = N,
    n_taxa = nrow(d)
  )
}

#Loop for each phentoype group
phenotypes <- sample_data(ps)$Host_Phenotype %>% unique() %>% as.character()

ncm_results <- list()

for (pheno in phenotypes) {
  
  ps_sub <- subset_samples(ps, Host_Phenotype == pheno)
  ps_sub <- prune_taxa(taxa_sums(ps_sub) > 0, ps_sub)   # drop taxa absent in this subset
  
  otu_mat <- as(otu_table(ps_sub), "matrix")
  if (taxa_are_rows(ps_sub)) otu_mat <- t(otu_mat)      # force samples x taxa orientation
  
  message("Fitting neutral model for: ", pheno,
          " (", nrow(otu_mat), " samples, ", ncol(otu_mat), " taxa)")
  
  ncm_results[[pheno]] <- fit_neutral_model(otu_mat)
}

#Summary table: m, R2, n taxa, % above/below/neutral
summary_table <- map_dfr(names(ncm_results), function(pheno) {
  res <- ncm_results[[pheno]]
  tab_prop <- prop.table(table(factor(
    res$data$fit_class,
    levels = c("Above prediction", "Below prediction", "Neutral (within prediction)")
  )))
  
  tibble(
    Host_Phenotype = pheno,
    m               = res$m,
    m_CI_low        = res$m.ci[1],
    m_CI_high       = res$m.ci[2],
    Nm              = res$Nm,
    R2              = res$R2,
    n_taxa          = res$n_taxa,
    pct_above       = round(100 * tab_prop[["Above prediction"]], 1),
    pct_below       = round(100 * tab_prop[["Below prediction"]], 1),
    pct_neutral     = round(100 * tab_prop[["Neutral (within prediction)"]], 1)
  )
})

