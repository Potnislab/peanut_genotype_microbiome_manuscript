phy_tree(d16S_peanut_phyloseq_Endo.rare) <-
  midpoint(phy_tree(d16S_peanut_phyloseq_Endo.rare))

set.seed(541)
library(phyloseq)   
library(vegan)  
library(ggplot2) 
library(RColorBrewer)

#Select phyloseq object
physeq <- d16S_peanut_phyloseq_Bulk.rare
# swap for:
# physeq <- d16S_peanut_phyloseq_Bulk.rare
# physeq <- d16S_peanut_phyloseq_Rhizo.rare

#Extract metadata so sample_data can be datafram for adonis2 and betadisper
meta <- data.frame(sample_data(physeq))

#Define groups and which distance matrices you want
group_vars <- c("Host_Phenotype", "Host_Genotype")
distances  <- c("bray", "unifrac")

#Pre-compute distances
dist_bray <- phyloseq::distance(physeq, method = "bray")

dist_unifrac <- phyloseq::distance(
  physeq,
  method = "unifrac",
  weighted = FALSE
)

#Create storage objects
results <- list()
plots   <- list()

#Define colros if needed. These were changed later in photoshop.
color_vals <- c(
  "Sensitive"     = "orangered1",
  "Water_saver"   = "palegreen3",
  "Water_spender" = "darkgoldenrod2"
)

#Main loop for PERMANVOA and betadisper
for (d in distances) {
  
#Select distance matrix
  if (d == "bray") {
    dist <- dist_bray
  }
  
  if (d == "unifrac") {
    dist <- dist_unifrac
  }
  
  #Align metadata to distance matrix
  meta_use <- meta[match(labels(dist), rownames(meta)), ]

  #PCoA Ordination
  ord <- ordinate(physeq, method = "PCoA", distance = d)
  
  #extract first two axes
  pcoa_df <- as.data.frame(ord$vectors[, 1:2])
  colnames(pcoa_df) <- c("PCoA1", "PCoA2")
  
  #attach metadata (already aligned indirectly for plotting consistency)
  pcoa_df <- cbind(pcoa_df, meta_use)
  
  #variance explained
  eig <- ord$values$Eigenvalues
  var_exp <- eig / sum(eig)
  
#loop over grouping variables 
  
  for (g in group_vars) {
    
    set.seed(123)  # ensures reproducible permutations
    
#PERMANOVA
    perm <- adonis2(
      dist ~ meta_use[[g]],
      permutations = 9999
    )

    #Betadisper
    disp <- betadisper(dist, meta_use[[g]])
    disp_test <- permutest(disp, permutations = 9999)
    
#Adding results to previously made storage objects
    results[[paste(d, g, sep = "_")]] <- data.frame(
      Distance = d,
      Grouping = g,
      Pseudo_F = perm$F[1],
      R2       = perm$R2[1],
      p_value  = perm$`Pr(>F)`[1],
      betadisper_p = disp_test$tab[1, "Pr(>F)"]
    )
    
#Cleaning labels for table creation and plots
    label <- paste0(
      "PERMANOVA\n",
      "F = ", round(perm$F[1], 2),
      "\nR² = ", round(perm$R2[1], 3),
      "\nP = ", signif(perm$`Pr(>F)`[1], 2),
      "\n\nBetadisper\nP = ", signif(disp_test$tab[1,"Pr(>F)"], 2)
    )
    
#Defining color scales
    if (g == "Host_Phenotype") {
      col_scale <- scale_colour_manual(values = color_vals)
    } else {
      col_scale <- scale_colour_brewer(palette = "Dark2")
    }
    
#Main plot that will loop through each variable automatically
    p <- ggplot(pcoa_df, aes(x = PCoA1, y = PCoA2, color = .data[[g]])) +
      
      #Points
      geom_point(size = 3.8, shape = 21, stroke = 0.8,
                 fill = "white", alpha = 0.9) +
      
      # group ellipses
      stat_ellipse(level = 0.95, linewidth = 1) +
      
      # custom colors
      col_scale +
      
      # clean background
      theme_minimal(base_size = 14) +
      
      theme(
        panel.grid.major = element_line(color = "grey85"),
        panel.grid.minor = element_line(color = "grey92"),
        panel.border = element_rect(color = "black", fill = NA, linewidth = 1),
        legend.title = element_text(face = "bold"),
        axis.title = element_text(face = "bold"),
        axis.text  = element_text(color = "black")
      ) +
      
      # axis labels with variance explained
      labs(
        x = paste0("PCoA1 (", round(100 * var_exp[1], 1), "%)"),
        y = paste0("PCoA2 (", round(100 * var_exp[2], 1), "%)"),
        colour = g,
        title = paste("16S Bulk Soil",
                      ifelse(d == "bray", "Bray-Curtis", "Unweighted UniFrac"),
                      "-",
                      g)
      ) +
      
      # stats annotation box
      annotate(
        "label",
        x = -Inf,
        y = Inf,
        hjust = -0.05,
        vjust = 1.1,
        label = label,
        size = 4,
        fill = "white",
        label.size = 0.3
      )
    
    plots[[paste(d, g, sep = "_")]] <- p
  }
}

