#Shapiro-wilk loop 
run_shapiro <- function(x) {
  x <- na.omit(x)
  
  if(length(x) < 3){
    return(data.frame(
      W_statistic = NA,
      P_value = NA,
      Normal = NA
    ))
  }
  
  test <- shapiro.test(x)
  
  data.frame(
    W_statistic = unname(test$statistic),
    P_value = test$p.value,
    Normal = ifelse(test$p.value > 0.05, "Yes", "No")
  )
}

