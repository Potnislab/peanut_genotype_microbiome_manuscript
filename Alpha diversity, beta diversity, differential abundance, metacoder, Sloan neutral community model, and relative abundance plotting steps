#---------------------------------------------------------------------Differential Abundance--------------------------------------------------------------------------
#DESeq2 pipeline with table creation steps

library(phyloseq)
library(DESeq2)
library(dplyr)
library(tibble)
library(flextable)
library(officer)

#Select dataset
ps <- d16S_peanut_phyloseq_Endosphere
# ps <- dITS_peanut_phyloseq_Bulk
# ps <- dITS_peanut_phyloseq_Rhizo

#Set output name
output_name <- "16S_Bulk"

#Cleaning object and collapsing to genus level for computation
ps <- tax_glom(ps, taxrank = "genus", NArm = TRUE)

#remove NA taxonomy
ps <- subset_taxa(ps, !is.na(genus))

#remove empty taxa
ps <- prune_taxa(taxa_sums(ps) > 0, ps)

#remove empty samples (important for endosphere in this dataset)
ps <- prune_samples(sample_sums(ps) > 0, ps)

#Filtering low abudnacne taxa
ps <- prune_taxa(taxa_sums(ps) >= 10, ps)

#Setting factor level
sample_data(ps)$Host_Phenotype <- factor(
  sample_data(ps)$Host_Phenotype,
  levels = c("Sensitive", "Water_saver", "Water_spender")
)

#building findal DESeq2 object 
dds <- phyloseq_to_deseq2(ps, ~ Host_Phenotype)

#using poscounts to exclude taxa that only contain zero reads. This was important for endosphere
dds <- estimateSizeFactors(dds, type = "poscounts")

#checking poscounts
if(any(is.na(sizeFactors(dds)))) {
  stop("NA size factors detected — check filtering steps")
}

#Running DESeq2
dds <- DESeq(dds, fitType = "parametric")

#Taxonomy table
tax <- as.data.frame(tax_table(ps))
tax$ASV <- rownames(tax)

#Defining comparisons to make
comparisons <- list(
  
  list(
    title = "Water Saver vs Sensitive",
    contrast = c("Host_Phenotype","Water_saver","Sensitive")
  ),
  
  list(
    title = "Water Spender vs Sensitive",
    contrast = c("Host_Phenotype","Water_spender","Sensitive")
  ),
  
  list(
    title = "Water Saver vs Water Spender",
    contrast = c("Host_Phenotype","Water_saver","Water_spender")
  )
  
)

#Word document to export table
doc <- read_docx()

doc <- body_add_par(
  doc,
  paste("DESeq2 Differential Abundance -", output_name),
  style = "heading 1"
)

#loop through comparisons
for(comp in comparisons){
  
  res <- results(dds, contrast = comp$contrast)
  
  res_df <- as.data.frame(res)
  res_df$ASV <- rownames(res_df)
  
  # join taxonomy
  res_df <- left_join(res_df, tax, by = "ASV")
  
  # filter significant
  sig <- res_df %>%
    filter(!is.na(padj), padj < 0.05) %>%
    arrange(padj)
  
  # clean table
  table_out <- sig %>%
    transmute(
      phylum,
      family,
      genus,
      `log2FoldChange` = round(log2FoldChange, 2),
      `padj` = signif(padj, 3)
    )
  
#Add section title
  doc <- body_add_par(doc, comp$title, style = "heading 2")
  
  doc <- body_add_par(
    doc,
    paste("Significant taxa:", nrow(table_out)),
    style = "Normal"
  )
  
#Format table
  ft <- flextable(table_out) %>%
    theme_booktabs() %>%
    fontsize(size = 8, part = "all") %>%
    bold(part = "header") %>%
    autofit()
  
  ft <- fit_to_width(ft, max_width = 6.5)
  
  doc <- body_add_flextable(doc, ft)
  
  doc <- body_add_par(doc, "", style = "Normal")
  
}

#Save output
print(
  doc,
  target = paste0(output_name, "_DESeq2_Supplementary.docx")
)

cat("\nDONE: DESeq2 pipeline completed successfully\n")


