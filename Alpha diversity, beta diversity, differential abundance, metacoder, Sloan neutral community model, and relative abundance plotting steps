#-----------------------------------Dissimilarity distance matrix calculations and PERMANOVA tests with exportable table---------------------------------------------------------------------
#Rooting trees before running phyloseq 
library(ape)
install.packages("phangorn")  # if not already installed
library(phangorn)
library(phyloseq)

##Trees were midpoint rooted prior to unifrac and weighted unifrac analyses
phy_tree(d16S_peanut_phyloseq_Bulk.rare) <-
  midpoint(phy_tree(d16S_peanut_phyloseq_Bulk.rare))

phy_tree(d16S_peanut_phyloseq_Rhizo.rare) <-
